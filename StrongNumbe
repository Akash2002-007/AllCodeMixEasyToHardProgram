package javaandwrapperclass;

public class StrongNumber {
	public static void main(String[] args) {
		
	
     int n=145;
     int original=n;
     int sum=0;
     
     while(n>0) {
    	 int digit=n%10;
    	 int fact=1;
    	  for(int i=1;i<=digit;i++) {
    		  fact*=i;
    	  }
    	  sum+=fact;
    	  n=n/10;
     }
     if(original==sum) {
    	 System.out.println("It is Strongnumber");
     }else {
    	 System.out.println("It is not Storng number");
     }
}}

