package javaandwrapperclass;

public class FibNumber {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
        int num=9;
        int a=0,b=1;
        
        for(int i=1;i<=num;i++) {
        	int c=a+b;
        	System.out.println(c);
        	a=b;
        	b=c;
        }
	}

}
