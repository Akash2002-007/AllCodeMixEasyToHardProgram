package javaandwrapperclass;

public class Test10 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
        int num=89,num1=90;
        char op='+';
        
        switch(op) {
        case '+':
        	System.out.println("Addition"+(num+num1));
             break;
        
	     case '-':
    	   System.out.println("Sub"+(num-num1));
    	
         break;
    
         case '*':
	      System.out.println("Mul"+(num*num1));
            break;
    
         case '/':
	       System.out.println("div"+(num/num1));
             break;
    
          case '%':
	     System.out.println("Mod"+(num%num1));
           break;

          default: System.out.println("Invalid Operatoe");
	
        }
        }
}
