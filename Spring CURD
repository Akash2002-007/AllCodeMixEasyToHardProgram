package com.example.demo;

public class Student8 {
  private int id;
  private String name;
  private int marks;
  public Student8(int id, String name, int marks) {
	super();
	this.id = id;                            
	this.name = name;
	this.marks = marks;                                    //BLC
  }
  public int getId() {
	return id;
  }
  public void setId(int id) {
	this.id = id;
  }
  public String getName() {
	return name;
  }
  public void setName(String name) {
	this.name = name;
  }
  public int getMarks() {
	return marks;
  }
  public void setMarks(int marks) {
	this.marks = marks;
  }  
}

package com.example.demo;

import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.jdbc.datasource.DriverManagerDataSource;

@Configuration
public class JdbceConfig {
	@Bean
	public DriverManagerDataSource addDMD() {
		DriverManagerDataSource add = new DriverManagerDataSource();
		add.setDriverClassName("com.mysql.cj.jdbc.Driver");
		add.setUrl("jdbc:mysql://localhost:3306/testdb");
		add.setUsername("root");                              //Config
		add.setPassword("Akash959827");
		return add;

	}

	@Bean
	public JdbcTemplate jdbcTemplate() {
		return new JdbcTemplate(addDMD());
	}
}

