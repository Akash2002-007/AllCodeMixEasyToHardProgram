package com.nit;

public class Primnumber {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
     int num=19;
     int temp=0;
     for(int i=2;i<num;i++) {
    	 if(num%i==0) {
    		 temp++;
    		
    	 }
     }
     if(temp==0 && num>1) {
    	 System.out.println("It is prime");
     }else {
    	 System.out.println("It is not prime");
     }
	}

}
