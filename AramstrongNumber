package com.nit;

public class AramstrongNumber {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
         int num=153;
         int temp=num;
         int sum=0;
         
         while(num>0) {
        	 int rem=num%10;
        	 sum+=rem*rem*rem;
        	 num=num/10;
         }
         if(sum==temp) {
        	 System.out.println("It is a Aramstrong number");
         }
         else {
        	 System.out.println("It is not aramstrong number");
         }
	}

}
