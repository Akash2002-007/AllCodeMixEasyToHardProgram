package com.nit.evenandodd;

public class Evenoddifelse {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		int num=79;
       for(int i=0;i<num;i++) {
    	   if(i%2==0) {
    		   System.out.println(i+"even ");
    	   }else {
    		   System.out.println(i+ " odd");
    	   }
       }
	}

}
