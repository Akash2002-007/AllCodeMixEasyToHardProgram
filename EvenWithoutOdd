package com.nit.skyio;

public class EvenWithoutOdd {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
        int num=9;
        
        if((num/2)*2==num) {
        	System.out.println("Even Number");
        }else {
        	System.out.println("Odd Number");
        }
	}

}
