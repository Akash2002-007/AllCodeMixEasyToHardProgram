package com.nit.skyio;

public class Consective {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
     
		int num[]= {1,1,1,0,1,1,1,1};
		  int count=0;
		  int consective=0;
		  
		  for(int i=0;i<num.length;i++) {
			  if(num[i]==1) {  
			 count++;
			 if(count>consective) {
				 consective=count;
			 }
			  }
			  else {
				 count=0;
			 }
		  }
		  System.out.println(consective+" ");
	}

}
